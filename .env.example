# =============================================
# goit-pythonweb-hw-10 — Конфігурація застосунку
# =============================================

# ==================== PostgreSQL ====================
POSTGRES_USER=postgres
POSTGRES_PASSWORD=strong_password_here
POSTGRES_DB=contacts_db
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# ==================== JWT ====================
# Згенеруй сильний секретний ключ (мінімум 32 символи)
JWT_SECRET=your_super_secret_jwt_key_change_in_production
JWT_ALGORITHM=HS256
JWT_EXPIRATION_SECONDS=3600

# ==================== Email (Brevo) ====================
# Заміни на реальні дані від Brevo
MAIL_USERNAME=your_login@smtp-brevo.com
MAIL_PASSWORD=xsmtpsib-your_actual_smtp_key_here

MAIL_FROM=your_verified_email@domain.com
MAIL_FROM_NAME=Contacts API

MAIL_SERVER=smtp-relay.brevo.com
MAIL_PORT=587
MAIL_STARTTLS=true
MAIL_SSL_TLS=false
USE_CREDENTIALS=true
VALIDATE_CERTS=true

# ==================== Cloudinary ====================
CLD_NAME=your_cloud_name
CLD_API_KEY=your_cloudinary_api_key
CLD_API_SECRET=your_cloudinary_api_secret

# ==================== CORS ====================
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:5173

# ==================== Logging ====================
LOG_LEVEL=INFO
# LOG_LEVEL=DEBUG   # для детального логування під час розробки